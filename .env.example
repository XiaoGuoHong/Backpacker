# ── Backpacker / SmartVoyage 环境变量模板 ──────────────────────────────
# 复制此文件为 .env 并填入你自己的值
# 注意：.env 文件不应提交到 Git

# 基础
APP_NAME=Backpacker
APP_ENV=dev
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=10

# 服务
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# 高德地图（Amap MCP Server 用）
# 免费注册: https://console.amap.com/dev/key/app
AMAP_API_KEY=
AMAP_JS_KEY=

# Unsplash 图片
# 免费注册: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# 天气数据源: amap | open-meteo | demo
WEATHER_SOURCE=open-meteo

# LLM（Planner 整合用，可选）
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# A2A 传输方式: http(跨进程) | in-process(测试/单机回退)
A2A_TRANSPORT=http
ATTRACTION_AGENT_URL=http://127.0.0.1:8002/tasks/send
WEATHER_AGENT_URL=http://127.0.0.1:8003/tasks/send
HOTEL_AGENT_URL=http://127.0.0.1:8004/tasks/send
A2A_TIMEOUT_MS=12000

# MCP
MCP_TRANSPORT=streamable-http
AMAP_MCP_URL=http://127.0.0.1:8001/mcp
MCP_HTTP_PATH=/mcp

# 缓存与限速（Amap MCP Server）
AMAP_CACHE_TTL=300
AMAP_RATE_LIMIT=10

# 安全
MAX_INPUT_LENGTH=512
RATE_LIMIT_PER_MINUTE=60
MAX_BODY_BYTES=1048576

# 结果数量限制
MAX_RESULTS=20
